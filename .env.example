PORT=3000

# Railway PostgreSQL sets this through the service variable reference:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Optional but strongly recommended for online hosting.
# Railway -> App service -> Variables
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-this-password

# Keep one shared app dataset. Change only if you want separate datasets.
APP_SNAPSHOT_ID=default
